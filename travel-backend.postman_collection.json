                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"title\": \"Swiss Alps Luxury Expedition\",\n    \"description\": \"A 10-day luxury trek through the heart of the Swiss Alps.\",\n    \"basePrice\": 125000,\n    \"category\": \"Luxury\",\n    \"location\": \"Zermatt\",\n    \"state\": \"Valais\",\n    \"country\": \"Switzerland\",\n    \"minAge\": 12,\n    \"maxAge\": 70,\n    \"highlights\": [\n        \"Glacier Express Ride\",\n        \"Matterhorn Base Camp\",\n        \"Luxury Spa Resorts\"\n    ],\n    \"departureOptions\": [\n        {\n            \"fromCity\": \"Zurich\",\n            \"toCity\": \"Zermatt\",\n            \"type\": \"TRAIN\",\n            \"departureTimeAndPlace\": \"08:00 AM, Zurich HB\",\n            \"totalDays\": 10,\n            \"totalNights\": 9,\n            \"priceAdjustment\": 0\n        },\n        {\n            \"fromCity\": \"Geneva\",\n            \"toCity\": \"Zermatt\",\n            \"type\": \"TRAIN\",\n            \"departureTimeAndPlace\": \"09:00 AM, Geneva Airport\",\n            \"totalDays\": 10,\n            \"totalNights\": 9,\n            \"priceAdjustment\": 5000\n        }\n    ],\n    \"itinerary\": [\n        {\n            \"dayNumber\": 1,\n            \"title\": \"Arrival in Zermatt\",\n            \"points\": [\n                {\n                    \"text\": \"Welcome meet and Greet\",\n                    \"subPoints\": [\n                        \"Transfer to 5-star hotel\",\n                        \"Briefing session\"\n                    ]\n                }\n            ]\n        },\n        {\n            \"dayNumber\": 2,\n            \"title\": \"Matterhorn Glacier Paradise\",\n            \"points\": [\n                {\n                    \"text\": \"Cable car ride to 3883m\",\n                    \"subPoints\": [\n                        \"Visit Glacier Palace\",\n                        \"Lunch at Peak Restaurant\"\n                    ]\n                }\n            ]\n        }\n    ],\n    \"inclusions\": [\n        \"All meals\",\n        \"5-star accommodation\",\n        \"Professional guides\"\n    ],\n    \"exclusions\": [\n        \"International flights\",\n        \"Personal insurance\"\n    ],\n    \"faqs\": [\n        {\n            \"question\": \"Is insurance mandatory?\",\n            \"answer\": \"Yes, full travel insurance is required.\"\n        }\n    ],\n    \"isActive\": true,\n    \"isFeatured\": true\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
